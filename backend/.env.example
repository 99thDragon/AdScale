# Copy this file to `.env` and fill in your key.
# Without a key the agent returns a deterministic mock campaign, so the API
# (and the frontend that calls it) still runs end-to-end for local dev.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Encrypts ad-platform OAuth tokens at rest (issue #27 / PRD §6c). Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, tokens are stored in plaintext (dev only — never in production).
TOKEN_ENCRYPTION_KEY=
