# Connect the frontend to the FastAPI backend by setting its base URL.
# Copy this file to `.env`.

# Local backend (run: cd backend && uvicorn app.main:app --port 8000):
VITE_API_BASE_URL=http://localhost:8000

# Leave VITE_API_BASE_URL unset (or delete .env) to run the UI on mock data
# with no backend.

# Production / custom backend host:
# VITE_API_BASE_URL=https://api.example.com
