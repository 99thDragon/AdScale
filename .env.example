# Copy to `.env` and fill in. All values are client-side (safe in the browser).

# --- Supabase Auth (Google sign-in) ---
# From Supabase -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Leave these unset to run auth in mock mode (no Supabase project needed).

# --- Backend API ---
# Local backend (cd backend && uvicorn app.main:app --port 8000):
VITE_API_BASE_URL=http://localhost:8000
# Leave unset to run the UI on mock data.
